@page "/data-files"
@using System.IO
@inject IJSRuntime JSRuntime

<PageTitle>Databestanden - MacroTracker</PageTitle>

<div class="container">
    <div class="row mb-4">
        <div class="col">
            <h1>Databestanden</h1>
        </div>
    </div>

    <div class="alert alert-info" role="alert">
        <strong>Let op:</strong> MacroTracker is een lokaal-eerst applicatie. Alle data wordt opgeslagen als platte
        JSON-tekstbestanden. Er is geen SQL-database, geen SQLite en geen database-afhankelijkheden.
    </div>

    <div class="card">
        <div class="card-header">
            <h5>Opslaglocatie van data</h5>
        </div>
        <div class="card-body">
            <p>
                <strong>App_Data-map:</strong>
            </p>
            <div class="input-group">
                <input class="form-control" type="text" value="@GetAppDataPath()" readonly
                       style="font-family: monospace;" />
            </div>
            <div class="d-flex align-items-center gap-2 mt-2">
                <small class="text-muted">Exporteer of importeer alle JSON-data als een .zip-bestand.</small>
            </div>
            <form action="/api/data-files/import" method="post" enctype="multipart/form-data"
                  class="mt-2 d-flex gap-2 align-items-center">
                <input id="zipFileInput" class="d-none" type="file" name="zipFile" accept=".zip" required
                       onchange="this.form.submit();" />
                <a class="btn btn-outline-primary" href="/api/data-files/export">Exporteren</a>
                <button class="btn btn-outline-primary" type="button"
                        onclick="document.getElementById('zipFileInput').click();">Importeren</button>
            </form>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col">
            <h5>JSON-bestanden</h5>
            <div class="list-group">
                <div class="list-group-item bg-light">
                    <div class="d-flex justify-content-between align-items-center gap-3">
                        <div>
                            <h6 class="mb-1">Alle</h6>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <small class="text-muted">@GetTotalFileSizeBytes() bytes</small>
                            <input class="form-check-input" type="checkbox" checked="@IsAllSelected"
                                   @onchange="ToggleAllSelections" />
                        </div>
                    </div>
                </div>
                @foreach (var dataFile in dataFiles)
                {
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between align-items-center gap-3">
                            <div>
                                <h6 class="mb-1">@dataFile.FileName</h6>
                                <p class="mb-1"><small class="text-muted">@dataFile.Description</small></p>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <small class="text-muted">@GetFileInfo(dataFile.FileName)</small>
                                <input class="form-check-input" type="checkbox"
                                       checked="@selectedFiles.Contains(dataFile.FileName)"
                                       @onchange="e => ToggleFileSelection(e, dataFile.FileName)" />
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="d-flex justify-content-end mt-3">
                <button class="btn btn-outline-danger btn-clear-selected" @onclick="ClearSelectedDataFilesAsync"
                        disabled="@(selectedFiles.Count == 0)">Wis geselecteerde bestanden</button>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col">
            <h5>Over deze applicatie</h5>
            <ul>
                <li>Gebouwd met <strong>C# en Blazor Server</strong></li>
                <li>Gebruikt <strong>System.Text.Json</strong> voor serialisatie</li>
                <li>Alle persistentie is bestand-gebaseerd met <strong>geen database-afhankelijkheden</strong></li>
                <li>Data is menselijk leesbare JSON, geschikt voor versiebeheer of handmatige bewerking</li>
                <li>Thread-veilige bestandsbewerkingen met <code>SemaphoreSlim</code></li>
                <li>Draait lokaal met <code>dotnet run</code></li>
            </ul>
        </div>
    </div>
</div>

@code {
    private readonly List<DataFileDescriptor> dataFiles =
    [
        new("foods.json", "Bevat alle ingredienten en producten met hun macrowaarden per 100g."),
        new("recipes.json", "Bevat alle recepten met ingrediënten en macroberekeningen."),
        new("daily-log.json", "Bevat dagelijkse voedings- en receptinvoer met datums en porties."),
        new("measurements.json", "Bevat dagelijkse lichaamsmetingen, waaronder gewicht en tailleomtrek."),
        new("personal-data.json", "Bevat profielgegevens van één gebruiker, zoals lengte, voor BMI- en ratio-berekeningen.")
    ];
    private readonly HashSet<string> selectedFiles = new(StringComparer.OrdinalIgnoreCase);
    private bool IsAllSelected => dataFiles.Count > 0 && selectedFiles.Count == dataFiles.Count;

    private string GetAppDataPath()
    {
        return Path.Combine(AppContext.BaseDirectory, "App_Data");
    }

    private string GetFileInfo(string fileName)
    {
        var filePath = Path.Combine(GetAppDataPath(), fileName);
        if (File.Exists(filePath))
        {
            var info = new FileInfo(filePath);
            return $"{info.Length} bytes";
        }
        return "0 bytes (nog niet aangemaakt)";
    }

    private long GetTotalFileSizeBytes()
    {
        var folderPath = GetAppDataPath();
        long total = 0;

        foreach (var file in dataFiles)
        {
            var filePath = Path.Combine(folderPath, file.FileName);
            if (File.Exists(filePath))
            {
                total += new FileInfo(filePath).Length;
            }
        }

        return total;
    }

    private void ToggleAllSelections(ChangeEventArgs e)
    {
        var isChecked = e.Value is bool b && b;
        selectedFiles.Clear();

        if (!isChecked)
        {
            return;
        }

        foreach (var dataFile in dataFiles)
        {
            selectedFiles.Add(dataFile.FileName);
        }
    }

    private void ToggleFileSelection(ChangeEventArgs e, string fileName)
    {
        var isChecked = e.Value is bool b && b;
        if (isChecked)
        {
            selectedFiles.Add(fileName);
        }
        else
        {
            selectedFiles.Remove(fileName);
        }
    }

    private async Task ClearSelectedDataFilesAsync()
    {
        if (selectedFiles.Count == 0)
        {
            return;
        }

        var filesToClear = selectedFiles.OrderBy(f => f).ToList();
        var fileList = string.Join(", ", filesToClear);

        var confirmed = await JSRuntime.InvokeAsync<bool>(
            "confirm",
            $"Waarschuwing: je staat op het punt de gegevens in deze bestanden te wissen: {fileList}. Deze actie kan niet ongedaan worden gemaakt. Doorgaan?");

        if (!confirmed)
        {
            return;
        }

        var folderPath = GetAppDataPath();
        Directory.CreateDirectory(folderPath);

        foreach (var fileName in filesToClear)
        {
            var filePath = Path.Combine(folderPath, fileName);
            await File.WriteAllTextAsync(filePath, "[]");
        }

        selectedFiles.Clear();

        await InvokeAsync(StateHasChanged);
    }

    private sealed record DataFileDescriptor(string FileName, string Description);
}
