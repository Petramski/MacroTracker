@page "/foods"
@inject FoodService FoodService
@inject DailyLogService DailyLogService

<PageTitle>Ingredienten - MacroTracker</PageTitle>

<div class="container">
    <div class="row mb-4">
        <div class="col">
            <h1>Ingredienten & producten</h1>
        </div>
        <div class="col text-end">
            <button class="btn btn-primary" @onclick="ShowAddForm">Ingredient toevoegen</button>
        </div>
    </div>

    @if (foods == null)
    {
        <p><em>Laden...</em></p>
    }
    else
    {
        <div class="row mb-3">
            <div class="col-md-6">
                <input type="text" class="form-control" placeholder="Zoek op naam of merk..." @oninput="OnSearchChanged" />
            </div>
        </div>

        @if (foods.Count == 0)
        {
            <p class="text-muted">Geen ingredienten gevonden. Voeg je eerste ingredient toe!</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>
                                <button type="button" class="btn btn-link p-0 text-decoration-none"
                                        @onclick="() => SortBy(SortColumn.Name)">
                                    Naam <span class="ms-1">@((MarkupString)GetSortIcon(SortColumn.Name))</span>
                                </button>
                            </th>
                            <th>
                                <button type="button" class="btn btn-link p-0 text-decoration-none"
                                        @onclick="() => SortBy(SortColumn.Brand)">
                                    Merk <span class="ms-1">@((MarkupString)GetSortIcon(SortColumn.Brand))</span>
                                </button>
                            </th>
                            <th>Eenheid</th>
                            <th>Energie (kcal)</th>
                            <th>Koolhydraten</th>
                            <th>Eiwit</th>
                            <th>Vet</th>
                            <th>Acties</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var food in filteredFoods)
                        {
                            <tr>
                                <td>@food.Name</td>
                                <td>@(food.Brand ?? "-")</td>
                                <td>
                                    <small class="badge bg-info">
                                        @MacroCalculator.GetUnitDisplayName(food.Unit)
                                        @if (food.Unit != FoodUnit.Grams)
                                        {
                                            <span>(@food.UnitWeightGrams g)</span>
                                        }
                                    </small>
                                </td>
                                <td>@food.CaloriesPer100g kcal</td>
                                <td>@food.CarbsPer100g g</td>
                                <td>@food.ProteinPer100g g</td>
                                <td>@food.FatPer100g g</td>
                                <td>
                                    <button class="btn btn-sm btn-warning" @onclick="() => EditFood(food)">Bewerken</button>
                                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteFood(food.Id)">Verwijderen</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }

    @if (showForm)
    {
        <div class="card mt-4">
            <div class="card-header">
                <h5>@(editingFood?.Id == Guid.Empty ? "Ingredient toevoegen" : "Ingredient bewerken")</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Naam *</label>
                    <input type="text" class="form-control" @bind="editingFood?.Name" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Merk</label>
                    <input type="text" class="form-control" @bind="editingFood.Brand" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Notities</label>
                    <textarea class="form-control" @bind="editingFood.Notes" rows="2"></textarea>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label">Eenheid *</label>
                        <select class="form-control" @bind="editingFood.Unit">
                            <option value="Grams">Grammen (g)</option>
                            <option value="Piece">Stuk</option>
                            <option value="Serving">Portie</option>
                            <option value="Cup">Kop</option>
                            <option value="Tablespoon">Eetlepel (el)</option>
                            <option value="Teaspoon">Theelepel (tl)</option>
                            <option value="Slice">Plak</option>
                            <option value="Handful">Handje</option>
                        </select>
                    </div>
                    @if (editingFood.Unit != FoodUnit.Grams)
                    {
                        <div class="col-md-6">
                            <label class="form-label">Gewicht per eenheid (gram) *</label>
                            <input type="number" class="form-control" @bind="editingFood.UnitWeightGrams" step="0.1" min="1" />
                            <small class="text-muted">bijv. 1 ei = 50g</small>
                        </div>
                    }
                </div>

                <div class="row">
                    <div class="col-md-3">
                        <label class="form-label">Energie per 100g (kcal) *</label>
                        <input type="number" class="form-control" @bind="editingFood.CaloriesPer100g" step="0.1" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Koolhydraten (g) *</label>
                        <input type="number" class="form-control" @bind="editingFood.CarbsPer100g" step="0.1" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Eiwit (g) *</label>
                        <input type="number" class="form-control" @bind="editingFood.ProteinPer100g" step="0.1" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Vet (g) *</label>
                        <input type="number" class="form-control" @bind="editingFood.FatPer100g" step="0.1" />
                    </div>
                </div>
                <div class="mt-3">
                    <button class="btn btn-success" @onclick="SaveFood">Opslaan</button>
                    <button class="btn btn-secondary" @onclick="HideForm">Annuleren</button>
                </div>
                <div class="mt-2">
                    <small class="text-muted">Velden met * zijn verplicht.</small>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<FoodItem> foods = new();
    private List<FoodItem> filteredFoods = new();
    private bool showForm = false;
    private FoodItem editingFood = new();
    private string searchTerm = "";
    private SortColumn sortColumn = SortColumn.Name;
    private bool sortAscending = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadFoods();
    }

    private async Task LoadFoods()
    {
        foods = await FoodService.GetAllAsync();
        ApplyFiltersAndSorting();
    }

    private void ShowAddForm()
    {
        try
        {
            editingFood = new FoodItem { Id = Guid.Empty, Unit = FoodUnit.Grams, UnitWeightGrams = 100 };
            showForm = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Error in ShowAddForm: {ex.Message}");
        }
    }

    private void EditFood(FoodItem food)
    {
        editingFood = new FoodItem
        {
            Id = food.Id,
            Name = food.Name,
            Brand = food.Brand,
            Notes = food.Notes,
            Unit = food.Unit,
            UnitWeightGrams = food.UnitWeightGrams,
            CaloriesPer100g = food.CaloriesPer100g,
            CarbsPer100g = food.CarbsPer100g,
            ProteinPer100g = food.ProteinPer100g,
            FatPer100g = food.FatPer100g
        };
        showForm = true;
        StateHasChanged();
    }

    private async Task SaveFood()
    {
        if (string.IsNullOrWhiteSpace(editingFood.Name) || editingFood.UnitWeightGrams <= 0)
        {
            return;
        }

        if (editingFood.Id == Guid.Empty)
        {
            await FoodService.AddAsync(editingFood);
        }
        else
        {
            await FoodService.UpdateAsync(editingFood);
        }

        await LoadFoods();
        HideForm();
    }

    private async Task DeleteFood(Guid foodId)
    {
        var isUsed = await FoodService.IsFoodUsedAsync(foodId);
        if (isUsed)
        {
            if (!await JSRuntime!.InvokeAsync<bool>("confirm", "Dit ingredient wordt gebruikt in daglogs. Toch verwijderen?"))
            {
                return;
            }
        }

        await FoodService.DeleteAsync(foodId);
        await LoadFoods();
    }

    private void HideForm()
    {
        showForm = false;
        editingFood = new();
        StateHasChanged();
    }

    private void OnSearchChanged(ChangeEventArgs e)
    {
        searchTerm = (string?)e.Value ?? "";
        ApplyFiltersAndSorting();
    }

    private void SortBy(SortColumn column)
    {
        if (sortColumn == column)
        {
            sortAscending = !sortAscending;
        }
        else
        {
            sortColumn = column;
            sortAscending = true;
        }

        ApplyFiltersAndSorting();
    }

    private string GetSortIcon(SortColumn column)
    {
        if (sortColumn != column)
        {
            return "&harr;";
        }

        return sortAscending ? "&uarr;" : "&darr;";
    }

    private void ApplyFiltersAndSorting()
    {
        var lowerSearch = searchTerm.ToLower();

        IEnumerable<FoodItem> query = foods.Where(f =>
            (f.Name?.ToLower().Contains(lowerSearch) ?? false) ||
            (f.Brand?.ToLower().Contains(lowerSearch) ?? false)
        );

        query = (sortColumn, sortAscending) switch
        {
            (SortColumn.Name, true) => query.OrderBy(f => f.Name),
            (SortColumn.Name, false) => query.OrderByDescending(f => f.Name),
            (SortColumn.Brand, true) => query.OrderBy(f => f.Brand ?? string.Empty).ThenBy(f => f.Name),
            (SortColumn.Brand, false) => query.OrderByDescending(f => f.Brand ?? string.Empty).ThenBy(f => f.Name),
            _ => query
        };

        filteredFoods = query.ToList();
    }

    private enum SortColumn
    {
        Name,
        Brand
    }

    [Inject] IJSRuntime? JSRuntime { get; set; }
    [Inject] MacroCalculator MacroCalculator { get; set; } = new();
}
