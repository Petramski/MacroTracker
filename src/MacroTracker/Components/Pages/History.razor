@page "/history"
@inject DailyLogService DailyLogService
@inject MeasurementService MeasurementService
@inject PersonalDataService PersonalDataService
@inject FoodService FoodService
@inject RecipeService RecipeService
@inject MacroCalculator MacroCalculator
@inject IJSRuntime JSRuntime

<PageTitle>Geschiedenis - MacroTracker</PageTitle>

<div class="container">
    <div class="row mb-4">
        <div class="col">
            <h1>Geschiedenis</h1>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-3">
            <label class="form-label">Van datum</label>
            <input type="date" class="form-control" value="@startDate.ToString("yyyy-MM-dd")"
                   @onchange="OnStartDateChanged" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Tot datum</label>
            <input type="date" class="form-control" value="@endDate.ToString("yyyy-MM-dd")"
                   @onchange="OnEndDateChanged" />
        </div>
    </div>

    @if (allEntries == null)
    {
        <p><em>Laden...</em></p>
    }
    else if (filteredDates.Count == 0)
    {
        <p class="text-muted">Geen invoer of metingen in het geselecteerde datumbereik.</p>
    }
    else
    {
        <div class="d-flex justify-content-end mb-2">
            <button class="btn btn-outline-danger" @onclick="DeleteSelectedAsync"
                    disabled="@(GetSelectedVisibleDates().Count == 0)">
                Verwijder
            </button>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th style="width: 1rem;">
                            <input class="form-check-input" type="checkbox" checked="@IsAllVisibleSelected"
                                   @onchange="ToggleAllVisibleSelections" />
                        </th>
                        <th>Datum</th>
                        <th>Energie (kcal)</th>
                        <th>Koolhydraten (g)</th>
                        <th>Eiwit (g)</th>
                        <th>Vet (g)</th>
                        <th>Gewicht (kg)</th>
                        <th>Taille (cm)</th>
                        <th>BMI</th>
                        <th>Taille/lengte</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var date in filteredDates)
                    {
                        var dayEntries = filteredEntries.Where(e => e.Date == date).ToList();
                        dayTotalsByDate.TryGetValue(date, out var dayMacros);
                        dayMacros ??= new MacroTotals();
                        measurementsByDate.TryGetValue(date, out var measurement);
                        var bmi = GetBmiValue(measurement);
                        var ratio = GetWaistToHeightRatioValue(measurement);
                        <tr>
                            <td>
                                <input class="form-check-input" type="checkbox" checked="@selectedDates.Contains(date)"
                                       @onchange="e => ToggleDateSelection(e, date)" />
                            </td>
                            <td>@date.ToString("dd-MM-yyyy")</td>
                            <td>@MacroCalculator.FormatCalories(dayMacros.Calories) kcal</td>
                            <td>@MacroCalculator.FormatMacro(dayMacros.Carbs)</td>
                            <td>@MacroCalculator.FormatMacro(dayMacros.Protein)</td>
                            <td>@MacroCalculator.FormatMacro(dayMacros.Fat)</td>
                            <td>@(measurement?.WeightKg > 0 ? MacroCalculator.FormatMacro(measurement.WeightKg) : "-")</td>
                            <td>@(measurement?.WaistCm > 0 ? MacroCalculator.FormatMacro(measurement.WaistCm) : "-")</td>
                            <td class="@MacroCalculator.GetBmiTableCellClass(bmi)">@GetBmiDisplay(bmi)</td>
                            <td class="@MacroCalculator.GetWaistToHeightTableCellClass(ratio)">
                                @GetWaistToHeightRatioDisplay(ratio)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="row mt-4">
                <div class="col">
                    <h5>Samenvatting van geselecteerde periode</h5>
                    <div class="row">
                        <div class="col-md-3">
                            <div class="card bg-light">
                                <div class="card-body">
                                    <h6 class="card-title">Gem. dagelijkse energie</h6>
                                    <h4>@MacroCalculator.FormatCalories(periodAverageTotals.Calories) kcal</h4>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card bg-light">
                                <div class="card-body">
                                    <h6 class="card-title">Gem. dagelijkse koolhydraten</h6>
                                    <h4>@MacroCalculator.FormatMacro(periodAverageTotals.Carbs)g</h4>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card bg-light">
                                <div class="card-body">
                                    <h6 class="card-title">Gem. dagelijks eiwit</h6>
                                    <h4>@MacroCalculator.FormatMacro(periodAverageTotals.Protein)g</h4>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card bg-light">
                                <div class="card-body">
                                    <h6 class="card-title">Gem. dagelijks vet</h6>
                                    <h4>@MacroCalculator.FormatMacro(periodAverageTotals.Fat)g</h4>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row mt-3">
                        <div class="col-md-3">
                            <div class="card bg-light">
                                <div class="card-body">
                                    <h6 class="card-title">Totale energie in periode</h6>
                                    <h4>@MacroCalculator.FormatCalories(periodTotalTotals.Calories) kcal</h4>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card bg-light">
                                <div class="card-body">
                                    <h6 class="card-title">Totale koolhydraten in periode</h6>
                                    <h4>@MacroCalculator.FormatMacro(periodTotalTotals.Carbs)g</h4>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card bg-light">
                                <div class="card-body">
                                    <h6 class="card-title">Totaal eiwit in periode</h6>
                                    <h4>@MacroCalculator.FormatMacro(periodTotalTotals.Protein)g</h4>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card bg-light">
                                <div class="card-body">
                                    <h6 class="card-title">Totaal vet in periode</h6>
                                    <h4>@MacroCalculator.FormatMacro(periodTotalTotals.Fat)g</h4>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-3">
                        <p class="text-muted">
                            <small>Dagen met voedselinvoer: @filteredEntries.GroupBy(e => e.Date).Count() | Dagen met metingen:
                                @allMeasurements.Count(m => m.Date >= startDate && m.Date <= endDate)</small>
                            </p>
                        </div>
                    </div>
                </div>
            }
        </div>

@code {
    private DateOnly startDate;
    private DateOnly endDate;
    private List<DailyLogEntry> allEntries = new();
    private List<DailyLogEntry> filteredEntries = new();
    private List<DailyMeasurement> allMeasurements = new();
    private Dictionary<DateOnly, DailyMeasurement> measurementsByDate = new();
    private Dictionary<DateOnly, MacroTotals> dayTotalsByDate = new();
    private List<DateOnly> filteredDates = new();
    private readonly HashSet<DateOnly> selectedDates = new();
    private PersonalData personalData = new();
    private MacroTotals periodAverageTotals = new();
    private MacroTotals periodTotalTotals = new();

    protected override async Task OnInitializedAsync()
    {
        endDate = DateOnly.FromDateTime(DateTime.Today);
        startDate = endDate.AddDays(-30);

        await LoadData();
    }

    private async Task LoadData()
    {
        allEntries = await DailyLogService.GetAllAsync();
        allMeasurements = await MeasurementService.GetAllAsync();
        personalData = await PersonalDataService.GetAsync();
        measurementsByDate = allMeasurements
            .GroupBy(m => m.Date)
            .ToDictionary(g => g.Key, g => g.OrderByDescending(m => m.UpdatedAt).First());

        await FilterAndCalculateAsync();
    }

    private async Task FilterAndCalculateAsync()
    {
        filteredEntries = allEntries.Where(e => e.Date >= startDate && e.Date <= endDate).ToList();
        var filteredMeasurementDates = allMeasurements
            .Where(m => m.Date >= startDate && m.Date <= endDate)
            .Select(m => m.Date);
        filteredDates = filteredEntries
            .Select(e => e.Date)
            .Concat(filteredMeasurementDates)
            .Distinct()
            .OrderBy(d => d)
            .ToList();

        var groupedByDay = filteredEntries.GroupBy(e => e.Date).ToList();
        dayTotalsByDate = new Dictionary<DateOnly, MacroTotals>();

        if (groupedByDay.Count == 0)
        {
            periodAverageTotals = new MacroTotals();
            periodTotalTotals = new MacroTotals();
            return;
        }

        periodTotalTotals = new MacroTotals();
        foreach (var dayGroup in groupedByDay)
        {
            var dayMacros = await CalculateDayTotalsAsync(dayGroup.ToList());
            dayTotalsByDate[dayGroup.Key] = dayMacros;
            periodTotalTotals.Calories += dayMacros.Calories;
            periodTotalTotals.Carbs += dayMacros.Carbs;
            periodTotalTotals.Protein += dayMacros.Protein;
            periodTotalTotals.Fat += dayMacros.Fat;
        }

        var daysCount = groupedByDay.Count;
        periodAverageTotals = new MacroTotals
        {
            Calories = periodTotalTotals.Calories / daysCount,
            Carbs = periodTotalTotals.Carbs / daysCount,
            Protein = periodTotalTotals.Protein / daysCount,
            Fat = periodTotalTotals.Fat / daysCount
        };
    }

    private bool IsAllVisibleSelected => filteredDates.Count > 0 && filteredDates.All(selectedDates.Contains);

    private List<DateOnly> GetSelectedVisibleDates()
    {
        return filteredDates.Where(selectedDates.Contains).OrderBy(date => date).ToList();
    }

    private void ToggleAllVisibleSelections(ChangeEventArgs e)
    {
        var isChecked = e.Value is bool value && value;

        foreach (var date in filteredDates)
        {
            if (isChecked)
            {
                selectedDates.Add(date);
            }
            else
            {
                selectedDates.Remove(date);
            }
        }
    }

    private void ToggleDateSelection(ChangeEventArgs e, DateOnly date)
    {
        var isChecked = e.Value is bool value && value;

        if (isChecked)
        {
            selectedDates.Add(date);
        }
        else
        {
            selectedDates.Remove(date);
        }
    }

    private async Task DeleteSelectedAsync()
    {
        var datesToDelete = GetSelectedVisibleDates();
        if (datesToDelete.Count == 0)
        {
            return;
        }

        var dateList = string.Join(", ", datesToDelete.Select(date => date.ToString("d")));
        var confirmed = await JSRuntime.InvokeAsync<bool>(
            "confirm",
            $"Waarschuwing: je staat op het punt {datesToDelete.Count} geselecteerde geschiedenisregel(s) te verwijderen voor: {dateList}. Dit verwijdert alle invoer en metingen voor deze datums. Deze actie is onomkeerbaar. Doorgaan?");

        if (!confirmed)
        {
            return;
        }

        foreach (var date in datesToDelete)
        {
            await DailyLogService.DeleteByDateAsync(date);
            await MeasurementService.DeleteByDateAsync(date);
            selectedDates.Remove(date);
        }

        await LoadData();
        await InvokeAsync(StateHasChanged);
    }

    private async Task<MacroTotals> CalculateDayTotalsAsync(List<DailyLogEntry> dayEntries)
    {
        var totals = new MacroTotals();
        foreach (var entry in dayEntries)
        {
            MacroTotals macros;

            if (entry.LoggedCalories.HasValue &&
                entry.LoggedCarbs.HasValue &&
                entry.LoggedProtein.HasValue &&
                entry.LoggedFat.HasValue)
            {
                macros = new MacroTotals
                {
                    Calories = entry.LoggedCalories.Value,
                    Carbs = entry.LoggedCarbs.Value,
                    Protein = entry.LoggedProtein.Value,
                    Fat = entry.LoggedFat.Value
                };
            }
            else
            {
                macros = await MacroCalculator.CalculateForEntryAsync(entry);
                entry.LoggedCalories = macros.Calories;
                entry.LoggedCarbs = macros.Carbs;
                entry.LoggedProtein = macros.Protein;
                entry.LoggedFat = macros.Fat;
                await DailyLogService.UpdateAsync(entry);
            }

            totals.Calories += macros.Calories;
            totals.Carbs += macros.Carbs;
            totals.Protein += macros.Protein;
            totals.Fat += macros.Fat;
        }

        return totals;
    }

    private decimal? GetBmiValue(DailyMeasurement? measurement)
    {
        if (measurement == null)
        {
            return null;
        }

        return MacroCalculator.CalculateBmi(measurement.WeightKg, personalData.HeightCm);
    }

    private string GetBmiDisplay(decimal? bmi)
    {
        return bmi.HasValue ? $"{bmi.Value:0.00}" : "-";
    }

    private decimal? GetWaistToHeightRatioValue(DailyMeasurement? measurement)
    {
        if (measurement == null)
        {
            return null;
        }

        return MacroCalculator.CalculateWaistToHeightRatio(measurement.WaistCm, personalData.HeightCm);
    }

    private string GetWaistToHeightRatioDisplay(decimal? ratio)
    {
        return ratio.HasValue ? $"{ratio.Value:0.00}" : "-";
    }

    private async Task OnStartDateChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse((string?)e.Value, out var date))
        {
            startDate = DateOnly.FromDateTime(date);
            await FilterAndCalculateAsync();
        }
    }

    private async Task OnEndDateChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse((string?)e.Value, out var date))
        {
            endDate = DateOnly.FromDateTime(date);
            await FilterAndCalculateAsync();
        }
    }
}
