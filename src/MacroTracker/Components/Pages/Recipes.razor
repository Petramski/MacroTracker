@page "/recipes"
@inject RecipeService RecipeService
@inject FoodService FoodService
@inject MacroCalculator MacroCalculator
@inject DailyLogService DailyLogService
@using MacroTracker.Models

<PageTitle>Recepten - MacroTracker</PageTitle>

<div class="container">
    <div class="row mb-4">
        <div class="col">
            <h1>Recepten</h1>
        </div>
        <div class="col text-end">
            <button class="btn btn-primary" @onclick="ShowAddForm">Recept toevoegen</button>
        </div>
    </div>

    @if (recipes == null || allFoods == null)
    {
        <p><em>Laden...</em></p>
    }
    else
    {
        @if (recipes.Count == 0)
        {
            <p class="text-muted">Geen recepten gevonden. Voeg je eerste recept toe!</p>
        }
        else
        {
            <div class="row">
                @foreach (var recipe in recipes)
                {
                    var recipeMacros = CalculateRecipeMacrosPerHundredGrams(recipe);
                    <div class="col-md-6 mb-3">
                        <div class="card">
                            <div class="card-body">
                                <h5 class="card-title">@recipe.Name</h5>
                                @if (!string.IsNullOrEmpty(recipe.Notes))
                                {
                                    <p class="card-text"><small>@recipe.Notes</small></p>
                                }
                                <p class="card-text">
                                    <small class="text-muted">
                                        Totaal bereid gewicht: @recipe.TotalPreparedWeightGrams g<br />
                                        Energie per 100g: @MacroCalculator.FormatCalories(recipeMacros.Calories) kcal,
                                        P: @MacroCalculator.FormatMacro(recipeMacros.Protein)g,
                                        C: @MacroCalculator.FormatMacro(recipeMacros.Carbs)g,
                                        F: @MacroCalculator.FormatMacro(recipeMacros.Fat)g
                                    </small>
                                </p>
                                <button class="btn btn-sm btn-warning" @onclick="() => EditRecipe(recipe)">Bewerken</button>
                                <button class="btn btn-sm btn-danger" @onclick="() => DeleteRecipe(recipe.Id)">Verwijderen</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }

    @if (showForm)
    {
        <div class="card mt-4">
            <div class="card-header">
                <h5>@(editingRecipe?.Id == Guid.Empty ? "Recept toevoegen" : "Recept bewerken")</h5>
            </div>
            <div class="card-body">
                @{
                    var editingRecipeMacros = CalculateEditingRecipeMacrosPerHundredGrams();
                }
                <div class="mb-3">
                    <label class="form-label">Receptnaam *</label>
                    <input type="text" class="form-control" @bind="editingRecipe!.Name" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Notities</label>
                    <textarea class="form-control" @bind="editingRecipe.Notes" rows="2"></textarea>
                </div>
                <div class="row mb-3">
                    <div class="col-md-4">
                        <label class="form-label">Totaal bereid gewicht (g) *</label>
                        <input type="number" class="form-control" @bind="editingRecipe.TotalPreparedWeightGrams" step="0.1"
                               readonly />
                        <small class="text-muted">Wordt automatisch berekend als som van ingrediënten.</small>
                    </div>
                    <div class="col-md-8">
                        <label class="form-label">Macro's per 100g bereiding</label>
                        <div class="form-control bg-light">
                            Energie: @MacroCalculator.FormatCalories(editingRecipeMacros.Calories) kcal,
                            P: @MacroCalculator.FormatMacro(editingRecipeMacros.Protein)g,
                            C: @MacroCalculator.FormatMacro(editingRecipeMacros.Carbs)g,
                            F: @MacroCalculator.FormatMacro(editingRecipeMacros.Fat)g
                        </div>
                    </div>
                </div>

                <h6>Ingrediënten</h6>
                <div class="mb-3">
                    @if (editingRecipe.Ingredients.Count == 0)
                    {
                        <p class="text-muted">Nog geen ingrediënten toegevoegd.</p>
                    }
                    else
                    {
                        <table class="table table-sm table-bordered">
                            <thead>
                                <tr>
                                    <th>Ingredient</th>
                                    <th>Hoeveelheid (g)</th>
                                    <th>Actie</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var (ingredient, index) in editingRecipe.Ingredients.Select((i, idx) => (i, idx)))
                                {
                                    var ingredientName = GetIngredientDisplayName(ingredient);
                                    <tr>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(ingredientName))
                                            {
                                                <span>@ingredientName</span>
                                            }
                                            else
                                            {
                                                <span class="text-danger">Ingredient niet gevonden</span>
                                            }
                                        </td>
                                        <td>@ingredient.AmountGrams</td>
                                        <td>
                                            <button class="btn btn-sm btn-danger"
                                                    @onclick="() => RemoveIngredient(index)">Verwijderen</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>

                <div class="row mb-3">
                    <div class="col-md-3">
                        <label class="form-label">Type</label>
                        <select class="form-control" @onchange="OnIngredientReferenceTypeChanged">
                            <option value="Food" selected="@(selectedIngredientType == FoodReferenceType.Food)">Ingredient
                            </option>
                            <option value="Recipe" selected="@(selectedIngredientType == FoodReferenceType.Recipe)">Recept
                            </option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Selecteer ingredient om toe te voegen</label>
                        <select class="form-control" @onchange="OnIngredientSelected">
                            <option value="">-- Kies --</option>
                            @if (selectedIngredientType == FoodReferenceType.Food)
                            {
                                @foreach (var food in allFoods ?? new())
                                {
                                    <option value="@food.Id">@food.Name</option>
                                }
                            }
                            else
                            {
                                @foreach (var recipe in GetAvailableSubRecipes())
                                {
                                    <option value="@recipe.Id">@recipe.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Hoeveelheid (@GetSelectedIngredientUnitLabel())</label>
                        <input type="number" class="form-control" @bind="ingredientAmount" step="1" />
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button class="btn btn-secondary w-100" @onclick="AddIngredient">Toevoegen</button>
                    </div>
                </div>

                <div class="mt-3">
                    <button class="btn btn-success" @onclick="SaveRecipe">Opslaan</button>
                    <button class="btn btn-secondary" @onclick="HideForm">Annuleren</button>
                </div>
                <div class="mt-2">
                    <small class="text-muted">Velden met * zijn verplicht.</small>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Recipe> recipes = new();
    private List<FoodItem> allFoods = new();
    private bool showForm = false;
    private Recipe editingRecipe = new();
    private Guid selectedIngredientId = Guid.Empty;
    private FoodReferenceType selectedIngredientType = FoodReferenceType.Food;
    private decimal ingredientAmount = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        recipes = await RecipeService.GetAllAsync();
        allFoods = await FoodService.GetAllAsync();
    }

    private void ShowAddForm()
    {
        editingRecipe = new Recipe { Id = Guid.Empty, Ingredients = new(), Unit = FoodUnit.Grams, UnitWeightGrams = 100 };
        selectedIngredientId = Guid.Empty;
        selectedIngredientType = FoodReferenceType.Food;
        ingredientAmount = 0;
        UpdateTotalPreparedWeight();
        showForm = true;
        StateHasChanged();
    }

    private void EditRecipe(Recipe recipe)
    {
        editingRecipe = new Recipe
        {
            Id = recipe.Id,
            Name = recipe.Name,
            Notes = recipe.Notes,
            Unit = recipe.Unit,
            UnitWeightGrams = recipe.UnitWeightGrams,
            TotalPreparedWeightGrams = recipe.TotalPreparedWeightGrams,
            Ingredients = recipe.Ingredients.Select(i => new RecipeIngredient
            {
                ReferenceType = i.ReferenceType,
                FoodItemId = i.FoodItemId,
                RecipeId = i.RecipeId,
                AmountGrams = i.AmountGrams
            }).ToList()
        };
        selectedIngredientId = Guid.Empty;
        selectedIngredientType = FoodReferenceType.Food;
        ingredientAmount = 0;
        UpdateTotalPreparedWeight();
        showForm = true;
        StateHasChanged();
    }

    private async Task SaveRecipe()
    {
        UpdateTotalPreparedWeight();

        if (string.IsNullOrWhiteSpace(editingRecipe.Name) || editingRecipe.TotalPreparedWeightGrams <= 0 ||
editingRecipe.Ingredients.Count == 0)
        {
            return;
        }

        if (await RecipeService.WouldCreateCircularReferenceAsync(editingRecipe))
        {
            await JSRuntime!.InvokeVoidAsync("alert", "Dit recept veroorzaakt een circulaire verwijzing via subrecepten.");
            return;
        }

        editingRecipe.Unit = FoodUnit.Grams;
        editingRecipe.UnitWeightGrams = 100;

        if (editingRecipe.Id == Guid.Empty)
        {
            await RecipeService.AddAsync(editingRecipe);
        }
        else
        {
            await RecipeService.UpdateAsync(editingRecipe);
        }

        await LoadData();
        HideForm();
    }

    private async Task DeleteRecipe(Guid recipeId)
    {
        var isUsed = await RecipeService.IsRecipeUsedAsync(recipeId);
        if (isUsed)
        {
            if (!await JSRuntime!.InvokeAsync<bool>("confirm", "Dit recept wordt gebruikt in daglogs. Toch verwijderen?"))
            {
                return;
            }
        }

        await RecipeService.DeleteAsync(recipeId);
        await LoadData();
    }

    private void HideForm()
    {
        showForm = false;
        editingRecipe = new();
        selectedIngredientId = Guid.Empty;
        selectedIngredientType = FoodReferenceType.Food;
        ingredientAmount = 0;
        StateHasChanged();
    }

    private void OnIngredientReferenceTypeChanged(ChangeEventArgs e)
    {
        var value = (string?)e.Value;
        selectedIngredientType = value == "Recipe" ? FoodReferenceType.Recipe : FoodReferenceType.Food;
        selectedIngredientId = Guid.Empty;
    }

    private void OnIngredientSelected(ChangeEventArgs e)
    {
        var value = (string?)e.Value;
        if (Guid.TryParse(value, out var guid))
        {
            selectedIngredientId = guid;

            if (selectedIngredientType == FoodReferenceType.Recipe)
            {
                var selectedRecipe = recipes.FirstOrDefault(r => r.Id == guid);
                if (selectedRecipe != null)
                {
                    ingredientAmount = selectedRecipe.TotalPreparedWeightGrams;
                }
            }
        }
        else
        {
            selectedIngredientId = Guid.Empty;
        }
    }

    private void AddIngredient()
    {
        if (selectedIngredientId == Guid.Empty || ingredientAmount <= 0)
        {
            return;
        }

        if (selectedIngredientType == FoodReferenceType.Recipe && editingRecipe.Id != Guid.Empty && selectedIngredientId ==
editingRecipe.Id)
        {
            return;
        }

        if (selectedIngredientType == FoodReferenceType.Food)
        {
            var selectedFood = allFoods.FirstOrDefault(f => f.Id == selectedIngredientId);
            if (selectedFood == null)
            {
                return;
            }

            var amountGrams = MacroCalculator.ConvertToGrams(ingredientAmount, selectedFood.Unit, selectedFood.UnitWeightGrams);
            editingRecipe.Ingredients.Add(new RecipeIngredient
            {
                ReferenceType = FoodReferenceType.Food,
                FoodItemId = selectedIngredientId,
                RecipeId = null,
                AmountGrams = amountGrams
            });
        }
        else
        {
            var selectedRecipe = recipes.FirstOrDefault(r => r.Id == selectedIngredientId);
            if (selectedRecipe == null)
            {
                return;
            }

            var amountGrams = MacroCalculator.ConvertToGrams(ingredientAmount, selectedRecipe.Unit, selectedRecipe.UnitWeightGrams);
            editingRecipe.Ingredients.Add(new RecipeIngredient
            {
                ReferenceType = FoodReferenceType.Recipe,
                FoodItemId = Guid.Empty,
                RecipeId = selectedIngredientId,
                AmountGrams = amountGrams
            });
        }

        UpdateTotalPreparedWeight();
        selectedIngredientId = Guid.Empty;
        ingredientAmount = 0;
    }

    private void RemoveIngredient(int index)
    {
        if (index >= 0 && index < editingRecipe.Ingredients.Count)
        {
            editingRecipe.Ingredients.RemoveAt(index);
            UpdateTotalPreparedWeight();
        }
    }

    private void UpdateTotalPreparedWeight()
    {
        editingRecipe.TotalPreparedWeightGrams = editingRecipe.Ingredients.Sum(i => i.AmountGrams);
    }

    private string GetSelectedIngredientUnitLabel()
    {
        if (selectedIngredientId == Guid.Empty)
        {
            return "eenheid";
        }

        if (selectedIngredientType == FoodReferenceType.Food)
        {
            var selectedFood = allFoods.FirstOrDefault(f => f.Id == selectedIngredientId);
            return selectedFood == null ? "eenheid" : MacroCalculator.GetUnitDisplayName(selectedFood.Unit);
        }

        var selectedRecipe = recipes.FirstOrDefault(r => r.Id == selectedIngredientId);
        return selectedRecipe == null ? "eenheid" : MacroCalculator.GetUnitDisplayName(selectedRecipe.Unit);
    }

    private IEnumerable<Recipe> GetAvailableSubRecipes()
    {
        return editingRecipe.Id == Guid.Empty
            ? recipes
            : recipes.Where(r => r.Id != editingRecipe.Id);
    }

    private string? GetIngredientDisplayName(RecipeIngredient ingredient)
    {
        if (ingredient.ReferenceType == FoodReferenceType.Recipe && ingredient.RecipeId.HasValue)
        {
            return recipes.FirstOrDefault(r => r.Id == ingredient.RecipeId.Value)?.Name;
        }

        return allFoods.FirstOrDefault(f => f.Id == ingredient.FoodItemId)?.Name;
    }

    private MacroTotals CalculateEditingRecipeMacrosPerHundredGrams()
    {
        var totalMacros = new MacroTotals();

        foreach (var ingredient in editingRecipe.Ingredients)
        {
            if (ingredient.ReferenceType == FoodReferenceType.Recipe && ingredient.RecipeId.HasValue)
            {
                var nestedRecipe = recipes.FirstOrDefault(r => r.Id == ingredient.RecipeId.Value);
                if (nestedRecipe == null)
                {
                    continue;
                }

                var nestedPerHundred = CalculateRecipeMacrosPerHundredGrams(nestedRecipe, new HashSet<Guid>());
                var nestedFactor = ingredient.AmountGrams / 100;
                totalMacros.Calories += nestedPerHundred.Calories * nestedFactor;
                totalMacros.Carbs += nestedPerHundred.Carbs * nestedFactor;
                totalMacros.Protein += nestedPerHundred.Protein * nestedFactor;
                totalMacros.Fat += nestedPerHundred.Fat * nestedFactor;
                continue;
            }

            var food = allFoods.FirstOrDefault(f => f.Id == ingredient.FoodItemId);
            if (food == null)
            {
                continue;
            }

            var factor = ingredient.AmountGrams / 100;
            totalMacros.Calories += food.CaloriesPer100g * factor;
            totalMacros.Carbs += food.CarbsPer100g * factor;
            totalMacros.Protein += food.ProteinPer100g * factor;
            totalMacros.Fat += food.FatPer100g * factor;
        }

        if (editingRecipe.TotalPreparedWeightGrams <= 0)
        {
            return new MacroTotals();
        }

        var perHundredFactor = 100 / editingRecipe.TotalPreparedWeightGrams;
        return new MacroTotals
        {
            Calories = totalMacros.Calories * perHundredFactor,
            Carbs = totalMacros.Carbs * perHundredFactor,
            Protein = totalMacros.Protein * perHundredFactor,
            Fat = totalMacros.Fat * perHundredFactor
        };
    }

    private MacroTotals CalculateRecipeMacrosPerHundredGrams(Recipe recipe)
    {
        return CalculateRecipeMacrosPerHundredGrams(recipe, new HashSet<Guid>());
    }

    private MacroTotals CalculateRecipeMacrosPerHundredGrams(Recipe recipe, HashSet<Guid> visitedRecipeIds)
    {
        if (recipe.Id != Guid.Empty && !visitedRecipeIds.Add(recipe.Id))
        {
            return new MacroTotals();
        }

        var totalMacros = new MacroTotals();

        foreach (var ingredient in recipe.Ingredients)
        {
            if (ingredient.ReferenceType == FoodReferenceType.Recipe && ingredient.RecipeId.HasValue)
            {
                var nestedRecipe = recipes.FirstOrDefault(r => r.Id == ingredient.RecipeId.Value);
                if (nestedRecipe == null)
                {
                    continue;
                }

                var nestedPerHundred = CalculateRecipeMacrosPerHundredGrams(nestedRecipe, visitedRecipeIds);
                var nestedFactor = ingredient.AmountGrams / 100;
                totalMacros.Calories += nestedPerHundred.Calories * nestedFactor;
                totalMacros.Carbs += nestedPerHundred.Carbs * nestedFactor;
                totalMacros.Protein += nestedPerHundred.Protein * nestedFactor;
                totalMacros.Fat += nestedPerHundred.Fat * nestedFactor;
                continue;
            }

            var food = allFoods.FirstOrDefault(f => f.Id == ingredient.FoodItemId);
            if (food == null)
            {
                continue;
            }

            var factor = ingredient.AmountGrams / 100;
            totalMacros.Calories += food.CaloriesPer100g * factor;
            totalMacros.Carbs += food.CarbsPer100g * factor;
            totalMacros.Protein += food.ProteinPer100g * factor;
            totalMacros.Fat += food.FatPer100g * factor;
        }

        if (recipe.TotalPreparedWeightGrams <= 0)
        {
            if (recipe.Id != Guid.Empty)
            {
                visitedRecipeIds.Remove(recipe.Id);
            }
            return new MacroTotals();
        }

        var perHundredFactor = 100 / recipe.TotalPreparedWeightGrams;
        var result = new MacroTotals
        {
            Calories = totalMacros.Calories * perHundredFactor,
            Carbs = totalMacros.Carbs * perHundredFactor,
            Protein = totalMacros.Protein * perHundredFactor,
            Fat = totalMacros.Fat * perHundredFactor
        };

        if (recipe.Id != Guid.Empty)
        {
            visitedRecipeIds.Remove(recipe.Id);
        }

        return result;
    }

    [Inject] IJSRuntime? JSRuntime { get; set; }
}
